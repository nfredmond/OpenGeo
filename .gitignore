# --- Node / Next.js ---
node_modules/
.pnpm-store/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# --- Env / secrets ---
.env
.env.*
!.env.example
!.env.test
*.key
*.pem

# Plaintext credential / provisioning notes — never commit.
private/
OpenGeo supabase info.md

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
logs/

# --- Test / coverage ---
coverage/
.nyc_output/
*.lcov

# --- Editor / OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo

# --- Vercel ---
.vercel/

# --- Supabase CLI ---
supabase/.branches/
supabase/.temp/

# --- Python (for ODM / AI pipelines) ---
.venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- Docker / data ---
data/
.docker/
docker/volumes/

# --- Large geo artifacts — never commit ---
*.tif
*.tiff
*.cog.tif
*.pmtiles
*.mbtiles
*.las
*.laz
*.copc.laz
*.shp
*.shx
*.dbf
*.prj
