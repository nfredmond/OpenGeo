# OpenGeo environment — copy to .env.local and fill in real values.
# .env.local is gitignored. Never commit real secrets.

# ---- Supabase ----
# Project ref: mqpkycymijjnhesrmmsr
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
# Server-only. Service role bypasses RLS — do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
# Direct Postgres URL (used by migrations, CLI, and background jobs only).
SUPABASE_DB_URL="postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres"

# ---- Local dev (docker-compose) ----
# Override when running against the local Postgres+PostGIS container.
LOCAL_DB_URL="postgresql://opengeo:opengeo@localhost:5433/opengeo"
LOCAL_MARTIN_URL="http://localhost:3001"
LOCAL_TITILER_URL="http://localhost:8000"
LOCAL_PG_FEATURESERV_URL="http://localhost:9000"

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=""
# Default model for NL→SQL and agentic tasks.
ANTHROPIC_MODEL="claude-opus-4-7"

# ---- Cloudflare R2 (object storage) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="opengeo-assets"
R2_PUBLIC_BASE_URL=""
# PMTiles publishing. If PMTILES_GENERATOR_URL is set, Next.js calls that
# service. Otherwise it runs TIPPECANOE_BIN locally.
TIPPECANOE_BIN="tippecanoe"
PMTILES_GENERATOR_URL=""
PMTILES_GENERATOR_TOKEN=""

# ---- MapLibre / basemap ----
# PMTiles URL for default basemap. Swap for your own PMTiles archive.
NEXT_PUBLIC_BASEMAP_PMTILES_URL=""
NEXT_PUBLIC_MARTIN_URL="http://localhost:3001"
# TiTiler endpoint used to render COG orthomosaics on the client.
NEXT_PUBLIC_TITILER_URL="http://localhost:8000"

# ---- OpenDroneMap (deferred: Phase 1 integration) ----
ODM_API_URL=""
ODM_API_TOKEN=""

# ---- AI feature extractor ----
# "mock" (default) returns synthetic polygons — zero setup, good for demos.
# "http" POSTs to services/extractor (docker compose profile extractor) for
# local dev, or to the Modal deployment in production. See ADR-002 and
# services/extractor/README.md.
OPENGEO_EXTRACTOR="mock"
OPENGEO_EXTRACTOR_URL=""
OPENGEO_EXTRACTOR_TOKEN=""

# ---- Feature flags ----
FEATURE_AI_NL_SQL="true"
FEATURE_AI_STYLE_GEN="true"
FEATURE_AI_FEATURE_EXTRACTION="false"
FEATURE_DRONE_PIPELINE="false"
# Kick off the Workflow DevKit pipeline after ODM submit instead of relying on
# manual /refresh polling. Requires a workflow backend (Vercel Workflows in
# prod, or `npx workflow web` locally).
FEATURE_DURABLE_PIPELINE="false"
